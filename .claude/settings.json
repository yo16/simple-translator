{
  "_note": "これは cc_dev_team の settings.json をこのプロジェクト用に調整した提案ファイルです。内容を確認のうえ、`settings.json` にリネームすると有効になります（リネーム例: ターミナルで `Rename-Item .claude/settings.json.proposed .claude/settings.json`）。権限の許可ルールを含むため、エージェントによる自動適用はされません。",
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",

      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git diff)",
      "Bash(git diff *)",
      "Bash(git branch)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git merge *)",
      "Bash(git log)",
      "Bash(git log *)",
      "Bash(git stash)",
      "Bash(git stash *)",
      "Bash(git worktree *)",
      "Bash(git show *)",
      "Bash(git reset *)",

      "Bash(gh pr *)",
      "Bash(gh api *)",

      "Bash(bd *)",

      "Bash(npm install)",
      "Bash(npm install *)",
      "Bash(npm test)",
      "Bash(npm test *)",
      "Bash(npm run *)",
      "Bash(npm ls *)",
      "Bash(npm create *)",
      "Bash(npx jest *)",
      "Bash(npx next *)",
      "Bash(npx eslint *)",
      "Bash(npx tsc *)",
      "Bash(npx tsc)",
      "Bash(npx tsx *)",
      "Bash(npx playwright *)",
      "Bash(npx create-next-app *)",

      "Bash(mkdir *)",
      "Bash(rm *)",
      "Bash(cp *)",
      "Bash(ls)",
      "Bash(ls *)",
      "Bash(pwd)",
      "Bash(node *)",
      "Bash(cat *)",

      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",

      "Agent(*)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Edit(.env*)",
      "Write(.env*)",
      "Edit(.git/**)",
      "Write(.git/**)"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(git branch -D *)",
      "Bash(npm uninstall *)"
    ]
  },
  "env": {
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "80"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "npx next lint --quiet 2>&1 || true"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "shell": "powershell",
            "command": "[System.Media.SystemSounds]::Exclamation.Play()"
          }
        ]
      }
    ]
  }
}
